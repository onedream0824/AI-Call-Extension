{
  "manifest_version": 3,
  "name": "AI Interview Assistant",
  "version": "1.0.0",
  "description": "Real-time AI coaching for freelancer interviews on Meet, Zoom, and Teams.",
  "permissions": ["sidePanel", "storage", "tabs", "scripting", "activeTab", "commands"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content-scripts/meet.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.zoom.us/wc/*", "https://*.zoom.us/j/*"],
      "js": ["src/content-scripts/zoom.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://teams.microsoft.com/*", "https://teams.live.com/*"],
      "js": ["src/content-scripts/teams.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "capture-captions": {
      "suggested_key": { "default": "Alt+Q" },
      "description": "Capture live captions from the active meeting tab"
    },
    "send-message": {
      "suggested_key": { "default": "Alt+W" },
      "description": "Send the captured text to the AI backend"
    }
  },
  "action": {
    "default_title": "Open AI Interview Assistant"
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
